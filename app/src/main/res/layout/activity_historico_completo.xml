<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- Título -->
    <TextView
        android:id="@+id/txtHistoricoTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/historico_titulo"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- EditText para busca -->
    <EditText
        android:id="@+id/edtBuscarHistorico"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/hint_buscar_despesa"
        android:inputType="text"
        android:autofillHints="none"
        app:layout_constraintTop_toBottomOf="@id/txtHistoricoTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- Spinner para filtro por mês -->
    <Spinner
        android:id="@+id/spinnerMesFiltro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/edtBuscarHistorico"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- ListView para mostrar despesas -->
    <ListView
        android:id="@+id/listViewHistorico"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:dividerHeight="8dp"
        app:layout_constraintTop_toBottomOf="@id/spinnerMesFiltro"
        app:layout_constraintBottom_toTopOf="@id/btnVoltarHistorico"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <!-- Botão Voltar -->
    <Button
        android:id="@+id/btnVoltarHistorico"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/voltar"
        app:layout_constraintBottom_toTopOf="@id/txtMarcaRodape"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"/>

    <!-- Rodapé "Saber mais" -->
    <TextView
        android:id="@+id/txtMarcaRodape"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/marca_app"
        android:textColor="@android:color/holo_blue_dark"
        android:textSize="16sp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
