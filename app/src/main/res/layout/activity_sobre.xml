<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/fundo_tela">

    <!-- Título -->
    <TextView
        android:id="@+id/txtTituloSobre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titulo_sobre"
        android:textColor="@color/titulo"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Conteúdo do aplicativo -->
    <ScrollView
        android:id="@+id/scrollSobre"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/txtTituloSobre"
        app:layout_constraintBottom_toTopOf="@id/btnVoltarSobre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/txtInfoApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/info_app"
            android:textSize="18sp"
            android:textColor="@color/titulo"
            android:lineSpacingExtra="4dp"/>
    </ScrollView>

    <!-- Botão Voltar -->
    <Button
        android:id="@+id/btnVoltarSobre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/voltar"
        android:backgroundTint="@color/botao_secundario"
        android:textColor="@color/botao_texto"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

