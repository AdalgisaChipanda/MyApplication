<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- Título -->
    <TextView
        android:id="@+id/txtResumoTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/resumo_mensal_titulo"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Total do mês -->
    <LinearLayout
        android:id="@+id/cardTotalMes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtResumoTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/txtTotalMesResumo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/total_mes_default"
            android:textSize="18sp"
            android:textColor="@android:color/black"/>
    </LinearLayout>

    <!-- Maior despesa -->
    <LinearLayout
        android:id="@+id/cardMaiorDespesa"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardTotalMes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/txtMaiorDespesa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/maior_despesa_default"
            android:textSize="18sp"
            android:textColor="@android:color/black"/>
    </LinearLayout>

    <!-- Menor despesa -->
    <LinearLayout
        android:id="@+id/cardMenorDespesa"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardMaiorDespesa"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/txtMenorDespesa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menor_despesa_default"
            android:textSize="18sp"
            android:textColor="@android:color/black"/>
    </LinearLayout>

    <!-- Categoria mais usada -->
    <LinearLayout
        android:id="@+id/cardCategoriaMaisUsada"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardMenorDespesa"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/txtCategoriaMaisUsada"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/categoria_mais_usada_default"
            android:textSize="18sp"
            android:textColor="@android:color/black"/>
    </LinearLayout>

    <!-- Botão Voltar -->
    <Button
        android:id="@+id/btnVoltarResumo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/voltar"
        app:layout_constraintTop_toBottomOf="@id/cardCategoriaMaisUsada"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- Rodapé Saber mais -->
    <TextView
        android:id="@+id/txtMarcaRodapeResumo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/marca_app"
        android:textColor="@android:color/holo_blue_dark"
        android:textSize="16sp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>

